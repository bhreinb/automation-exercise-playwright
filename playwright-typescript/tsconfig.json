{
  "compilerOptions": {
    "target": "ES2021",
    "lib": ["ES2021", "DOM"],
    "module": "CommonJS",
    "moduleResolution": "node10",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@expectations/*": ["functional/src/expectations/*"],
      "@facade/*": ["functional/src/facade/*"],
      "@fixtures/*": ["functional/src/fixtures/*"],
      "@models/*": ["functional/src/models/*"],
      "@payloads/*": ["functional/src/payloads/*"],
      "@support/*": ["functional/src/support/*"]
    }
  },
  "include": ["functional/src/**/*.ts", "functional/tests/**/*.ts"],
  "exclude": ["node_modules", "playwright-report", "test-results", "dist"]
}
