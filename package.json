{
  "name": "automation-exercise-playwright",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test:ci": "cross-env CI=true npx playwright test",
    "test:smoke": "npx playwright test --grep @smoke",
    "test:regression": "npx playwright test --grep @regression",
    "test:api": "npx playwright test --project=api",
    "test:ui": "npx playwright test --project=ui",
    "test:integration": "npx playwright test --project=integration",
    "test:headed": "npx playwright test --headed --project=ui --project=integration",
    "report:playwright": "npx playwright show-report",
    "allure:generate": "allure generate allure-results -o allure-report --clean",
    "allure:open": "allure open allure-report",
    "allure:serve": "allure serve allure-results",
    "clean": "rimraf allure-results allure-report playwright-report test-results results.xml"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@faker-js/faker": "^10.4.0",
    "@playwright/test": "^1.60.0",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/node": "^25.9.1",
    "allure-commandline": "^2.42.0",
    "allure-playwright": "^3.9.0",
    "cross-env": "^10.1.0",
    "eslint": "^9.0.0",
    "eslint-plugin-perfectionist": "^4.0.0",
    "fluent-ffmpeg": "^2.1.3",
    "prettier": "^3.8.3",
    "rimraf": "^6.0.0",
    "typescript-eslint": "^8.0.0"
  }
}
